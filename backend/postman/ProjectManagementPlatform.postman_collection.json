            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Design Homepage\",\n  \"description\": \"Create homepage wireframes\",\n  \"projectId\": 1,\n  \"assignedTo\": 2,\n  \"priority\": \"HIGH\",\n  \"status\": \"TODO\",\n  \"dueDate\": \"2026-08-01T00:00:00.000Z\"\n}"
            }
          }
